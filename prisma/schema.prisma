generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  COMPANY_OWNER
  WORKER
  CLIENT
}

enum OrganizationType {
  BEAUTY
  DENTAL
  MEDICAL
  AUTO_SERVICE
  BARBERSHOP
  SPA
  OTHER
}

enum SubscriptionPlan {
  FREE
  BASIC
  PRO
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELED
}

enum CompanyMemberRole {
  OWNER
  MANAGER
  WORKER
}

enum CompanyMemberStatus {
  INVITED
  ACTIVE
  DISABLED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  DECLINED
  CANCELED
  COMPLETED
  NO_SHOW
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  passwordHash    String
  phone           String?
  firstName       String?
  lastName        String?
  avatarUrl       String?
  role            UserRole
  isEmailVerified Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  ownedCompanies Company[]       @relation("CompanyOwner")
  memberships    CompanyMember[]
  workerProfiles WorkerProfile[]
  clientProfile   ClientProfile?
  bookings        Booking[]       @relation("ClientBookings")
}

model Company {
  id               String           @id @default(uuid())
  ownerId          String
  name             String
  slug             String           @unique
  description      String?
  phone            String?
  email            String?
  website          String?
  logoUrl          String?
  coverImageUrl    String?
  organizationType OrganizationType
  address          String?
  city             String?
  country          String?
  isActive         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  owner        User                 @relation("CompanyOwner", fields: [ownerId], references: [id])
  certificates CompanyCertificate[]
  subscription Subscription?
  members      CompanyMember[]
  services     Service[]
  workers      WorkerProfile[]
  bookings     Booking[]
  reports      WorkerReport[]
}

model CompanyCertificate {
  id        String    @id @default(uuid())
  companyId String
  title     String
  fileUrl   String
  issuedBy  String?
  issuedAt  DateTime?
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Subscription {
  id        String             @id @default(uuid())
  companyId String            @unique
  plan      SubscriptionPlan   @default(BASIC)
  status    SubscriptionStatus @default(TRIAL)
  maxWorkers Int              @default(5)
  startedAt DateTime           @default(now())
  expiresAt DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model CompanyMember {
  id              String              @id @default(uuid())
  companyId       String
  userId          String?
  role            CompanyMemberRole
  status          CompanyMemberStatus @default(INVITED)
  invitedEmail    String?
  inviteCode      String?
  inviteExpiresAt DateTime?
  joinedAt        DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])

  @@unique([companyId, userId])
}

model WorkerProfile {
  id              String   @id @default(uuid())
  userId          String
  companyId       String
  position        String?
  bio             String?
  photoUrl        String?
  experienceYears Int?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user          User                 @relation(fields: [userId], references: [id])
  company       Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  services      WorkerService[]
  availability  WorkerAvailability[]
  timeOffs      WorkerTimeOff[]
  bookings      Booking[]
  reports       WorkerReport[]

  @@unique([userId, companyId])
}

model Service {
  id              String   @id @default(uuid())
  companyId       String
  name            String
  description     String?
  price           Decimal  @db.Decimal(10, 2)
  durationMinutes Int
  category        String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workers WorkerService[]
  bookings Booking[]
}

model WorkerService {
  id              String   @id @default(uuid())
  workerProfileId String
  serviceId       String
  createdAt       DateTime @default(now())

  workerProfile WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  service       Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([workerProfileId, serviceId])
}

model WorkerAvailability {
  id              String  @id @default(uuid())
  workerProfileId String
  dayOfWeek       Int
  startTime       String
  endTime         String
  isActive        Boolean @default(true)

  workerProfile WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
}

model WorkerTimeOff {
  id              String   @id @default(uuid())
  workerProfileId String
  startDateTime   DateTime
  endDateTime     DateTime
  reason          String?
  createdAt       DateTime @default(now())

  workerProfile WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
}

model ClientProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  dateOfBirth DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Booking {
  id              String        @id @default(uuid())
  companyId       String
  clientId        String
  workerProfileId String
  serviceId       String
  startDateTime   DateTime
  endDateTime     DateTime
  status          BookingStatus @default(PENDING)
  clientNote      String?
  cancelReason    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client        User          @relation("ClientBookings", fields: [clientId], references: [id])
  workerProfile WorkerProfile @relation(fields: [workerProfileId], references: [id])
  service       Service       @relation(fields: [serviceId], references: [id])
}

model WorkerReport {
  id                String   @id @default(uuid())
  companyId         String
  workerProfileId   String
  periodStart       DateTime
  periodEnd         DateTime
  totalBookings     Int      @default(0)
  completedBookings Int      @default(0)
  canceledBookings  Int      @default(0)
  totalRevenue      Decimal  @default(0) @db.Decimal(10, 2)
  createdAt         DateTime @default(now())

  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workerProfile WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
}